# Production Environment Variables Template
# Copy this to .env.local for frontend and server/.env for backend
# Replace with your actual production values

# Frontend Environment Variables (.env.local)
VITE_API_BASE_URL=https://your-backend-url.onrender.com/api
VITE_FIREBASE_API_KEY=your_production_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_GOOGLE_CLIENT_ID=your_production_google_client_id

# Backend Environment Variables (server/.env)
MONGO_URI=your_mongodb_atlas_production_uri
JWT_SECRET=your_secure_random_jwt_secret_min_32_chars
GOOGLE_CLIENT_ID=your_production_google_client_id
PORT=5000
CLIENT_ORIGIN=https://your-frontend-url.onrender.com